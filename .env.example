# 生产环境配置模板
# 使用方法: cp .env.example .env，然后填写真实值
# 注意: .env 文件不要提交到 git！

# 服务器公网 IP 或域名（不带 http:// 和结尾斜杠）
SERVER_HOST=your.server.ip

# Nginx 对外暴露的端口（生产用 80，联调测试可用 5678 等非标端口）
NGINX_PORT=80

# MySQL root 密码（请使用强密码）
MYSQL_ROOT_PASSWORD=your_strong_password_here

# CSDN 消息推送（可选，不配置则推送功能不生效）
CSDN_APP_KEY=your_app_key
CSDN_APP_SECRET=your_app_secret

# 豆包大模型 API Key（用于 AI 智能解析、标签推荐、生成简介/背景图）
# 在火山引擎控制台创建：https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here
