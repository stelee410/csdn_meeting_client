<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csdn.meeting.infrastructure.repository.mapper.ParticipantPOMapper">

    <select id="selectByMeetingId" resultType="com.csdn.meeting.infrastructure.po.ParticipantPO">
        SELECT * FROM t_participant WHERE meeting_id = #{meetingId}
    </select>

    <select id="selectByMeetingIdAndUserId" resultType="com.csdn.meeting.infrastructure.po.ParticipantPO">
        SELECT * FROM t_participant WHERE meeting_id = #{meetingId} AND user_id = #{userId} LIMIT 1
    </select>
</mapper>
