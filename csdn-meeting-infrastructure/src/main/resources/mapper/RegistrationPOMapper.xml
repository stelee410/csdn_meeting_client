<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csdn.meeting.infrastructure.repository.mapper.RegistrationPOMapper">

    <select id="selectPageByMeetingIdAndStatus" resultType="com.csdn.meeting.infrastructure.po.RegistrationPO">
        SELECT * FROM t_registration WHERE meeting_id = #{meetingId} AND status = #{status}
    </select>

    <select id="selectPageByMeetingId" resultType="com.csdn.meeting.infrastructure.po.RegistrationPO">
        SELECT * FROM t_registration WHERE meeting_id = #{meetingId}
    </select>

    <select id="selectByUserIdAndMeetingId" resultType="com.csdn.meeting.infrastructure.po.RegistrationPO">
        SELECT * FROM t_registration WHERE user_id = #{userId} AND meeting_id = #{meetingId} LIMIT 1
    </select>

    <select id="selectByMeetingIdAndPhone" resultType="com.csdn.meeting.infrastructure.po.RegistrationPO">
        SELECT * FROM t_registration WHERE meeting_id = #{meetingId} AND phone = #{phone}
    </select>

    <select id="selectPageByUserIdAndMeetingStatusIn" resultType="com.csdn.meeting.infrastructure.po.RegistrationPO">
        SELECT r.* FROM t_registration r
        INNER JOIN t_meeting m ON r.meeting_id = m.id
        WHERE r.user_id = #{userId} AND m.status IN
        <foreach collection="statusCodes" item="c" open="(" separator="," close=")">
            #{c}
        </foreach>
        ORDER BY m.start_time DESC
    </select>
</mapper>
