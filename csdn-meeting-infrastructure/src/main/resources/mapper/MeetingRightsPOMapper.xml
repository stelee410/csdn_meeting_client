<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csdn.meeting.infrastructure.repository.mapper.MeetingRightsPOMapper">

    <select id="selectFirstByMeetingIdAndStatus" resultType="com.csdn.meeting.infrastructure.po.MeetingRightsPO">
        SELECT * FROM t_meeting_rights WHERE meeting_id = #{meetingId} AND status = #{status} LIMIT 1
    </select>

    <select id="selectByMeetingId" resultType="com.csdn.meeting.infrastructure.po.MeetingRightsPO">
        SELECT * FROM t_meeting_rights WHERE meeting_id = #{meetingId}
    </select>
</mapper>
